    {t:"Hit verb 동치미",     s:"핵심 동사 하나로 수십 가지 표현 정복",       m:"2027-10", d:"10월",      on:0, fin:0}
  ];
  var L = [
    {t:"영어로 그림전도",     s:"시각적 도구로 복음을 전하는 직관적 전도 영어",    m:"2026-04", d:"4월 21일", on:1, fin:0, url:"https://jc.co.kr/product/영어로-그림전도/"},
    {t:"로마서 8장",          s:"성령과 구원의 확신을 깊이 있게 새기는 말씀 묵상",  m:"2026-04", d:"4월 21일", on:1, fin:0, url:"https://jc.co.kr/product/정철의-로마서-통독암송/"},
    {t:"산상수훈 1권",        s:"예수님의 고귀한 가르침을 원문으로 묵상",           m:"2026-05", d:"5월 중순",  on:0, fin:0},
    {t:"야고보서 1권",        s:"행함이 있는 믿음을 영어 말씀으로 체득",            m:"2026-05", d:"5월 하순",  on:0, fin:0},
    {t:"야고보서 2권",        s:"행함이 있는 믿음을 영어 말씀으로 체득",            m:"2026-06", d:"6월",       on:0, fin:0},
    {t:"요한복음 1권",        s:"정철대학이 제안하는 성경 영어의 정석",             m:"2026-07", d:"7월",       on:0, fin:0},
    {t:"산상수훈 2권",        s:"산상수훈 완결",                                    m:"2026-07", d:"7월",       on:0, fin:1},
    {t:"요한복음 2권",        s:"정철대학이 제안하는 성경 영어의 정석",             m:"2026-08", d:"8월",       on:0, fin:0},
    {t:"야고보서 3권",        s:"야고보서 완결",                                    m:"2026-08", d:"8월",       on:0, fin:1},
    {t:"요한복음 3권",        s:"정철대학이 제안하는 성경 영어의 정석",             m:"2026-09", d:"9월",       on:0, fin:0},
    {t:"요한복음 4권",        s:"정철대학이 제안하는 성경 영어의 정석",             m:"2026-10", d:"10월",      on:0, fin:0},
    {t:"요한복음 5권",        s:"정철대학이 제안하는 성경 영어의 정석",             m:"2026-11", d:"11월",      on:0, fin:0},
    {t:"요한복음 6권",        s:"A세트 완결",                                       m:"2026-12", d:"12월",      on:0, fin:1},
    {t:"요나서",              s:"순종의 여정으로 배우는 생생한 묘사 영어",           m:"2027-01", d:"1월",       on:0, fin:0},
    {t:"요셉이야기 1~2권",    s:"꿈과 비전을 담은 요셉의 일대기 영어 정복",         m:"2027-03", d:"3월",       on:0, fin:0},
    {t:"요셉이야기 3~4권",    s:"꿈과 비전을 담은 요셉의 일대기 영어 정복",         m:"2027-04", d:"4월",       on:0, fin:0},
    {t:"요셉이야기 5권",      s:"요셉이야기 완결",                                  m:"2027-06", d:"6월",       on:0, fin:1},
    {t:"요한일서 1권",        s:"사랑과 진리의 메시지를 담은 깊이 있는 묵상",       m:"2027-06", d:"6월",       on:0, fin:0},
    {t:"요한복음 7권",        s:"정철대학이 제안하는 성경 영어의 정석",             m:"2027-07", d:"7월",       on:0, fin:0},
    {t:"요한일서 2권",        s:"사랑과 진리의 메시지를 담은 깊이 있는 묵상",       m:"2027-07", d:"7월",       on:0, fin:0},
    {t:"요한복음 8권",        s:"정철대학이 제안하는 성경 영어의 정석",             m:"2027-08", d:"8월",       on:0, fin:0},
    {t:"요한일서 3권",        s:"요한일서 완결",                                    m:"2027-08", d:"8월",       on:0, fin:1},
    {t:"요한복음 9권",        s:"정철대학이 제안하는 성경 영어의 정석",             m:"2027-09", d:"9월",       on:0, fin:0},
    {t:"요한복음 10권",       s:"정철대학이 제안하는 성경 영어의 정석",             m:"2027-10", d:"10월",      on:0, fin:0},
    {t:"요한복음 11권",       s:"정철대학이 제안하는 성경 영어의 정석",             m:"2027-11", d:"11월",      on:0, fin:0},
    {t:"요한복음 12권",       s:"요영통 완결",                                      m:"2027-12", d:"12월",      on:0, fin:1}
  ];

  var MONTHS = [
    "2026-04","2026-05","2026-06","2026-07","2026-08","2026-09",
    "2026-10","2026-11","2026-12",
    "2027-01","2027-02","2027-03","2027-04","2027-05","2027-06",
    "2027-07","2027-08","2027-09","2027-10","2027-11","2027-12"
  ];

  function gn(m) { return m.split("-")[1].replace(/^0/, ""); }
  function gy(m) { return m.split("-")[0]; }
  function is27(m) { return gy(m) === "2027"; }
  function bm(arr, m) { return arr.filter(function(c){ return c.m === m; }); }

  /* ── 숫자 카운팅 애니메이션 ── */
  function countUp(el, target, dur) {
    var start = 0, step = target / (dur / 16);
    var timer = setInterval(function() {
      start += step;
      if (start >= target) { start = target; clearInterval(timer); }
      el.textContent = Math.floor(start).toLocaleString();
    }, 16);
  }

  /* ── 카드 HTML ── */
  var delay = 0.3;
  function nd() { var d = delay; delay += 0.05; return d; }

  function cardHTML(c, tp) {
    var fin = c.fin;
    var on  = c.on;
    var cls = "card fu ";
    if (fin)       cls += "c-fin";
    else if (tp==="u") cls += (on ? "cu-on" : "cu-off");
    else               cls += (on ? "cl-on" : "cl-off");
    if (c.url) cls += " lnk";

    var onclick = c.url ? " onclick=\"window.open('" + c.url + "','_blank')\"" : "";
    var arr     = c.url ? "<span class='c-arr'>↗</span> " : "";
    var badge   = fin ? "🎉 시리즈 완결" : (on ? "✅ 공개 완료" : "📅 공개 예정");
    var d = nd();

    return "<div class='" + cls + "'" + onclick + " style='animation-delay:" + d.toFixed(2) + "s;animation-play-state:paused;'>"
      + "<div class='c-date'>" + c.d + "</div>"
      + "<div class='c-title'>" + arr + c.t + "</div>"
      + "<div class='c-sub'>" + c.s + (fin ? " 🎉" : "") + "</div>"
      + "<div class='c-status'>" + badge + "</div>"
      + "</div>";
  }

  /* ── 메인 렌더 ── */
  function render() {
    var out = document.getElementById("jcrm-content");
    if (!out) return;
    var html = "";
    var prevYr = "";

    MONTHS.forEach(function(m) {
      var uc = bm(U, m), lc = bm(L, m);
      if (!uc.length && !lc.length) return;
      var yr = gy(m); var y = is27(m);

      if (yr !== prevYr) {
        prevYr = yr;
        html += "<div class='year-banner fl' style='animation-delay:" + nd().toFixed(2) + "s;animation-play-state:paused;'>"
          + "<div class='year-num " + (y ? "y27" : "y26") + "'>" + yr + "</div>"
          + "<div class='year-line " + (y ? "y27" : "y26") + "'></div>"
          + "</div>";
      }

      html += "<div class='month-section' id='ms-" + m + "' data-ms='" + m + "'>";
      html += "<div class='month-head " + (y ? "y27" : "y26") + " fl' style='animation-delay:" + nd().toFixed(2) + "s;animation-play-state:paused;'>"
        + "<span class='month-num-big'>" + gn(m) + "</span>"
        + "<span class='month-ko'>월</span>"
        + "</div>";

      if (uc.length) {
        html += "<div class='course-lbl u'><div class='course-lbl-dot'></div>전공 과정</div>";
        html += "<div class='card-grid' style='margin-bottom:14px;'>";
        uc.forEach(function(c){ html += cardHTML(c, "u"); });
        html += "</div>";
      }
      if (lc.length) {
        html += "<div class='course-lbl l'><div class='course-lbl-dot'></div>평생 과정</div>";
        html += "<div class='card-grid'>";
        lc.forEach(function(c){ html += cardHTML(c, "l"); });
        html += "</div>";
      }
      html += "</div><div class='divider'></div>";
    });

    out.innerHTML = html;

    /* IntersectionObserver 등장 */
    if ("IntersectionObserver" in window) {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) {
            e.target.style.animationPlayState = "running";
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.06 });
      document.querySelectorAll("#jcrm .fu, #jcrm .fl").forEach(function(el) {
        obs.observe(el);
      });
    }
  }

  /* ── 탭 네비 렌더 ── */
  function buildNav() {
    var nav = document.getElementById("jcrm-nav");
    if (!nav) return;
    var active = MONTHS.filter(function(m){ return bm(U,m).length || bm(L,m).length; });
    var html = "<div class='nav-inner' id='nav-inner'>";
    var prevYr = "";
    active.forEach(function(m) {
      var yr = gy(m); var y = is27(m);
      if (yr !== prevYr) {
        if (prevYr) html += "<div class='nav-divider'></div>";
        html += "<div class='nav-year-lbl " + (y ? "y27" : "y26") + "'>" + yr + "</div>";
        prevYr = yr;
      }
      html += "<button class='nav-btn' data-m='" + m + "' onclick='jcrmGo(\"" + m + "\")'>"
        + "<span class='nav-num'>" + gn(m) + "</span>"
        + "<span class='nav-ko'>월</span>"
        + "</button>";
    });
    html += "</div>";
    nav.innerHTML = html;
    if (active.length) setActive(active[0]);
  }

  function setActive(m) {
    var btns = document.querySelectorAll("#jcrm-nav .nav-btn");
    btns.forEach(function(b) {
      b.classList.remove("on26", "on27");
      if (b.getAttribute("data-m") === m) {
        b.classList.add(is27(m) ? "on27" : "on26");
        var inner = document.getElementById("nav-inner");
        if (inner) {
          inner.scrollTo({ left: b.offsetLeft - inner.offsetWidth / 2 + b.offsetWidth / 2, behavior: "smooth" });
        }
      }
    });
  }

  window.jcrmGo = function(m) {
    var el = document.getElementById("ms-" + m);
    if (!el) return;
    var nav = document.getElementById("jcrm-nav");
    var off = (nav ? nav.offsetHeight : 60) + 10;
    window.scrollTo({ top: el.getBoundingClientRect().top + window.pageYOffset - off, behavior: "smooth" });
    setActive(m);
  };

  /* 스크롤 → active 탭 갱신 */
  (function() {
    var tick = false;
    window.addEventListener("scroll", function() {
      if (tick) return; tick = true;
      requestAnimationFrame(function() {
        var nav = document.getElementById("jcrm-nav");
        var navH = nav ? nav.offsetHeight : 60;
        var cur = null;
        document.querySelectorAll("[data-ms]").forEach(function(s) {
          if (s.getBoundingClientRect().top <= navH + 80) cur = s.getAttribute("data-ms");
        });
        if (cur) setActive(cur);
        tick = false;
      });
    });
  })();

  /* ── 카운팅 숫자 ── */
  function startCount() {
    var eu = document.getElementById("cnt-u");
    var el = document.getElementById("cnt-l");
    if (eu) countUp(eu, 1316, 1800);
    if (el) countUp(el, 2564, 1800);
  }

  /* ── 헤더 카운터: 화면에 보이면 시작 ── */
  function initCounter() {
    var stat = document.querySelector("#jcrm .hd-stats");
    if (!stat) { startCount(); return; }
    if ("IntersectionObserver" in window) {
      var o = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) { startCount(); o.disconnect(); }
      }, { threshold: 0.3 });
      o.observe(stat);
    } else {
      startCount();
    }
  }

  /* ── 초기화 ── */
  function init() { render(); buildNav(); initCounter(); }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>
