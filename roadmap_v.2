<style id="jcrm-style">
/* 엘리멘토 여백 제거 */
.elementor-widget-html .elementor-widget-container,
.elementor-widget-html .elementor-column-wrap,
.elementor-widget-html .elementor-column,
.elementor-widget-html .elementor-row,
.elementor-widget-html .e-con-inner {
  padding-left: 0 !important;
  padding-right: 0 !important;
  max-width: 100% !important;
}

#jcrm-outer {
  width: 100vw;
  position: relative;
  left: 50%;
  margin-left: -50vw;
  overflow-x: hidden;
  box-sizing: border-box;
}

#jcrm {
  font-family: 'Pretendard', 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif;
  background: #0D0D0D;
  color: #ffffff;
  box-sizing: border-box;
  width: 100%;
  -webkit-font-smoothing: antialiased;
}
#jcrm * { box-sizing: inherit; }

/* ── 애니메이션 ── */
@keyframes jcrm-fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes jcrm-fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes jcrm-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.3; }
}
@keyframes jcrm-slideLeft {
  from { opacity: 0; transform: translateX(-20px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ── 헤더 ── */
#jcrm .hd {
  background: #0D0D0D;
  padding: 100px 60px 90px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 24px;
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid #222;
  animation: jcrm-fadeIn .8s ease both;
}
#jcrm .hd::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 60% 50% at 20% 50%, rgba(245,166,35,.07) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 80% 50%, rgba(56,189,248,.05) 0%, transparent 60%);
  pointer-events: none;
}
#jcrm .hd-eyebrow {
  font-size: 13px; letter-spacing: 6px; font-weight: 700;
  color: #F5A623; text-transform: uppercase;
  animation: jcrm-fadeUp .6s ease .1s both;
}
#jcrm .hd-title {
  font-family: 'Pretendard', 'Apple SD Gothic Neo', sans-serif;
  font-size: 72px; font-weight: 900; line-height: 1.2; margin: 0;
  background: linear-gradient(135deg, #fff 30%, #F5A623 70%, #FFB84D 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -2px;
  animation: jcrm-fadeUp .7s ease .2s both;
}
#jcrm .hd-sub {
  font-size: 20px; color: #888; font-weight: 600; margin: 0;
  animation: jcrm-fadeUp .6s ease .3s both;
}
#jcrm .hd-stats {
  display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;
  animation: jcrm-fadeUp .6s ease .4s both;
}
#jcrm .hd-stat {
  padding: 22px 40px; border-radius: 18px; text-align: center;
}
#jcrm .st-u { background: rgba(245,166,35,.10); border: 1.5px solid rgba(245,166,35,.3); }
#jcrm .st-l { background: rgba(56,189,248,.10); border: 1.5px solid rgba(56,189,248,.3); }
#jcrm .hd-n {
  font-family: 'Pretendard', sans-serif;
  font-size: 52px; font-weight: 900; line-height: 1; letter-spacing: -2px;
}
#jcrm .st-u .hd-n { color: #F5A623; }
#jcrm .st-l .hd-n { color: #38BDF8; }
#jcrm .hd-t { font-size: 16px; color: #888; font-weight: 700; margin-top: 6px; }

/* ── 범례 ── */
#jcrm .legend {
  display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
  padding: 20px 40px; background: #0D0D0D; border-bottom: 1px solid #1e1e1e;
  animation: jcrm-fadeUp .5s ease .5s both;
}
#jcrm .leg {
  display: flex; align-items: center; gap: 8px;
  padding: 9px 18px; border-radius: 30px;
  font-size: 16px; font-weight: 800;
}
#jcrm .leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

/* ── 월 탭 네비게이션 ── */
#jcrm .month-nav {
  position: sticky; top: 0; z-index: 999;
  background: rgba(13,13,13,.95);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid #222;
  animation: jcrm-fadeIn .5s ease .6s both;
}
#jcrm .nav-inner {
  display: flex; align-items: stretch; overflow-x: auto;
  scrollbar-width: none; padding: 0 20px; gap: 0;
}
#jcrm .nav-inner::-webkit-scrollbar { display: none; }
#jcrm .nav-year-lbl {
  display: flex; align-items: center;
  font-family: 'Pretendard', sans-serif;
  font-size: 11px; font-weight: 900; letter-spacing: 3px;
  padding: 0 14px 0 6px; flex-shrink: 0; border-right: 1px solid #2a2a2a;
  margin-right: 4px;
}
#jcrm .nav-year-lbl.y26 { color: #F5A623; }
#jcrm .nav-year-lbl.y27 { color: #38BDF8; }
#jcrm .nav-divider { width: 1px; background: #2a2a2a; margin: 10px 6px; flex-shrink: 0; }
#jcrm .nav-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 12px 14px; background: none; border: none; cursor: pointer;
  font-family: 'Pretendard', 'Apple SD Gothic Neo', sans-serif;
  color: #555; white-space: nowrap; flex-shrink: 0;
  position: relative; transition: color .18s; gap: 3px;
}
#jcrm .nav-btn::after {
  content: ''; position: absolute; bottom: 0; left: 50%; right: 50%;
  height: 3px; border-radius: 3px 3px 0 0;
  background: #F5A623; transition: left .18s, right .18s;
}
#jcrm .nav-btn:hover { color: #fff; }
#jcrm .nav-btn:hover::after { left: 8%; right: 8%; }
#jcrm .nav-btn.on26 { color: #F5A623; }
#jcrm .nav-btn.on26::after { left: 8%; right: 8%; background: #F5A623; }
#jcrm .nav-btn.on27 { color: #38BDF8; }
#jcrm .nav-btn.on27::after { left: 8%; right: 8%; background: #38BDF8; }
#jcrm .nav-num { font-size: 22px; font-weight: 900; line-height: 1; }
#jcrm .nav-ko  { font-size: 11px; font-weight: 700; opacity: .65; }

/* ── 연도 배너 ── */
#jcrm .year-banner {
  padding: 32px 40px 20px;
  display: flex; align-items: center; gap: 20px;
}
#jcrm .year-num {
  font-family: 'Pretendard', 'Apple SD Gothic Neo', sans-serif;
  font-size: 80px; font-weight: 900; line-height: 1; letter-spacing: -4px;
}
#jcrm .year-num.y26 {
  background: linear-gradient(135deg, #F5A623, #FFB84D);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
#jcrm .year-num.y27 {
  background: linear-gradient(135deg, #38BDF8, #7DD3FC);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
#jcrm .year-line { flex: 1; height: 2px; }
#jcrm .year-line.y26 { background: linear-gradient(90deg, #F5A623, transparent); }
#jcrm .year-line.y27 { background: linear-gradient(90deg, #38BDF8, transparent); }

/* ── 월 섹션 ── */
#jcrm .month-section { padding: 0 40px 44px; }
#jcrm .month-head {
  display: flex; align-items: baseline; gap: 10px;
  margin-bottom: 24px; padding-left: 10px;
  border-left: 5px solid;
}
#jcrm .month-head.y26 { border-color: #F5A623; }
#jcrm .month-head.y27 { border-color: #38BDF8; }
#jcrm .month-num-big {
  font-family: 'Pretendard', 'Apple SD Gothic Neo', sans-serif;
  font-size: 60px; font-weight: 900; color: #fff;
  line-height: 1; letter-spacing: -2px;
}
#jcrm .month-ko {
  font-family: 'Pretendard', 'Apple SD Gothic Neo', sans-serif;
  font-size: 26px; font-weight: 700; color: #666;
}

/* ── 카드 그리드 ── */
#jcrm .card-grid { display: grid; gap: 14px; grid-template-columns: repeat(2, 1fr); }
@media (min-width: 900px)  { #jcrm .card-grid { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 1200px) { #jcrm .card-grid { grid-template-columns: repeat(4, 1fr); } }

/* ── 과정 라벨 ── */
#jcrm .course-lbl {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: 'Pretendard', 'Apple SD Gothic Neo', sans-serif;
  font-size: 18px; font-weight: 900; letter-spacing: 2px;
  margin-bottom: 12px; padding: 0 4px;
}
#jcrm .course-lbl.u { color: #F5A623; }
#jcrm .course-lbl.l { color: #38BDF8; }
#jcrm .course-lbl-dot { width: 8px; height: 8px; border-radius: 50%; }
#jcrm .course-lbl.u .course-lbl-dot { background: #F5A623; }
#jcrm .course-lbl.l .course-lbl-dot { background: #38BDF8; }

/* ── 카드 ── */
#jcrm .card {
  border-radius: 20px; padding: 26px 24px 24px;
  display: flex; flex-direction: column; gap: 14px;
  min-height: 200px; position: relative; overflow: hidden;
  transition: transform .2s, box-shadow .2s; cursor: default;
}
#jcrm .card.lnk { cursor: pointer; }
#jcrm .card:hover { transform: translateY(-5px); }
#jcrm .card::before {
  content: ''; position: absolute; top: 0; right: 0;
  width: 120px; height: 120px; border-radius: 50%; pointer-events: none;
}
/* 전공 완료 — AMBER */
#jcrm .cu-on {
  background: linear-gradient(140deg, #1c1200, #2e1f00, #3d2900);
  box-shadow: 0 0 0 1.5px #F5A623, 0 8px 32px rgba(245,166,35,.22);
}
#jcrm .cu-on::before { background: radial-gradient(circle, rgba(245,166,35,.16) 0%, transparent 70%); }
/* 전공 예정 */
#jcrm .cu-off {
  background: #181818;
  box-shadow: 0 0 0 1px #2e2e2e, 0 4px 16px rgba(0,0,0,.4);
}
/* 평생 완료 — SKY BLUE */
#jcrm .cl-on {
  background: linear-gradient(140deg, #001424, #001f3d, #002952);
  box-shadow: 0 0 0 1.5px #38BDF8, 0 8px 32px rgba(56,189,248,.20);
}
#jcrm .cl-on::before { background: radial-gradient(circle, rgba(56,189,248,.16) 0%, transparent 70%); }
/* 평생 예정 */
#jcrm .cl-off {
  background: #181818;
  box-shadow: 0 0 0 1px #2e2e2e, 0 4px 16px rgba(0,0,0,.4);
}
/* 시리즈 완결 — ORANGE */
#jcrm .c-fin {
  background: linear-gradient(140deg, #1c0800, #2e1200, #3d1900);
  box-shadow: 0 0 0 2px #FF6B00, 0 8px 40px rgba(255,107,0,.35);
}
#jcrm .c-fin::before { background: radial-gradient(circle, rgba(255,107,0,.22) 0%, transparent 70%); }
/* 공개예정 워터마크 */
#jcrm .cu-off::after, #jcrm .cl-off::after {
  content: 'COMING SOON';
  position: absolute; top: 14px; right: 14px;
  font-size: 9px; font-weight: 900; letter-spacing: 2px;
  color: #444; pointer-events: none;
}

/* 날짜 배지 */
#jcrm .c-date {
  display: inline-flex; align-items: center;
  padding: 7px 16px; border-radius: 30px;
  font-size: 18px; font-weight: 800;
  align-self: flex-start; position: relative; z-index: 1;
}
#jcrm .cu-on  .c-date { background: rgba(245,166,35,.18); color: #F5A623; }
#jcrm .cu-off .c-date { background: #2a2a2a; color: #666; animation: jcrm-blink 2.2s ease-in-out infinite; }
#jcrm .cl-on  .c-date { background: rgba(56,189,248,.18); color: #38BDF8; }
#jcrm .cl-off .c-date { background: #2a2a2a; color: #666; animation: jcrm-blink 2.2s ease-in-out infinite; }
#jcrm .c-fin  .c-date { background: rgba(255,107,0,.18); color: #FF6B00; }

/* 제목 */
#jcrm .c-title {
  font-family: 'Pretendard', 'Apple SD Gothic Neo', sans-serif;
  font-size: 26px; font-weight: 800; line-height: 1.3;
  position: relative; z-index: 1;
}
#jcrm .cu-on  .c-title { color: #FFB84D; }
#jcrm .cu-off .c-title { color: #bbb; }
#jcrm .cl-on  .c-title { color: #7DD3FC; }
#jcrm .cl-off .c-title { color: #bbb; }
#jcrm .c-fin  .c-title { color: #FF8C33; }

/* 서브 */
#jcrm .c-sub {
  font-size: 17px; font-weight: 600; line-height: 1.65;
  flex: 1; position: relative; z-index: 1;
}
#jcrm .cu-on  .c-sub { color: rgba(245,166,35,.72); }
#jcrm .cu-off .c-sub { color: #555; }
#jcrm .cl-on  .c-sub { color: rgba(56,189,248,.72); }
#jcrm .cl-off .c-sub { color: #555; }
#jcrm .c-fin  .c-sub { color: rgba(255,107,0,.72); }

/* 상태 배지 */
#jcrm .c-status {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 18px; border-radius: 20px;
  font-size: 16px; font-weight: 900;
  align-self: flex-start; position: relative; z-index: 1;
}
#jcrm .cu-on  .c-status { background: #F5A623; color: #000; }
#jcrm .cu-off .c-status { background: #1e1e1e; color: #555; border: 1px solid #333; }
#jcrm .cl-on  .c-status { background: #38BDF8; color: #000; }
#jcrm .cl-off .c-status { background: #1e1e1e; color: #555; border: 1px solid #333; }
#jcrm .c-fin  .c-status { background: #FF6B00; color: #fff; }

#jcrm .c-arr { font-size: 13px; opacity: .55; position: relative; z-index: 1; }

/* 구분선 */
#jcrm .divider { height: 1px; background: linear-gradient(90deg, transparent, #2a2a2a, transparent); margin: 0 40px 36px; }

/* 카드 등장 */
#jcrm .fu { opacity: 0; animation: jcrm-fadeUp .5s ease forwards; }
#jcrm .fl { opacity: 0; animation: jcrm-slideLeft .45s ease forwards; }

/* 푸터 */
#jcrm .foot {
  text-align: center; padding: 28px 20px;
  font-size: 14px; color: #444; font-weight: 600;
  background: #0D0D0D; border-top: 1px solid #1e1e1e;
}

/* 모바일 */
@media (max-width: 767px) {
  #jcrm .hd { padding: 64px 20px 52px; }
  #jcrm .hd-title { font-size: 42px; letter-spacing: -1px; }
  #jcrm .hd-sub { font-size: 17px; }
  #jcrm .hd-n { font-size: 44px; }
  #jcrm .hd-stat { padding: 18px 28px; }
  #jcrm .year-banner { padding: 24px 20px 16px; }
  #jcrm .year-num { font-size: 58px; }
  #jcrm .month-section { padding: 0 16px 36px; }
  #jcrm .month-num-big { font-size: 48px; }
  #jcrm .month-ko { font-size: 20px; }
  #jcrm .card-grid { grid-template-columns: 1fr; }
  #jcrm .c-title { font-size: 23px; }
  #jcrm .c-sub { font-size: 15px; }
  #jcrm .c-date { font-size: 16px; }
  #jcrm .legend { padding: 14px 12px; gap: 8px; }
  #jcrm .leg { font-size: 14px; padding: 8px 14px; }
  #jcrm .divider { margin: 0 16px 28px; }
  #jcrm .course-lbl { font-size: 16px; }
}
</style>

