<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
.jc-roadmap-wrap * {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.jc-roadmap-wrap {
  font-family: 'Pretendard Variable', 'Noto Sans KR', sans-serif;
  background: #f0f4ff;
  border-radius: 24px;
  overflow: hidden;
}

/* ── 상단 배너 ── */
.jc-roadmap-banner {
  background: #3b5bdb;
  padding: 200px 40px 140px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.jc-roadmap-banner::before {
  content: '';
  position: absolute;
  top: -100px; left: -100px;
  width: 400px; height: 400px;
  background: rgba(255,255,255,0.06);
  border-radius: 50%;
}

.jc-roadmap-banner::after {
  content: '';
  position: absolute;
  bottom: -80px; right: -80px;
  width: 320px; height: 320px;
  background: rgba(255,255,255,0.06);
  border-radius: 50%;
}

.jc-roadmap-banner h2 {
  font-size: clamp(42px, 7vw, 88px);
  font-weight: 900;
  color: #ffffff;
  letter-spacing: -2px;
  line-height: 1.15;
  position: relative;
  z-index: 1;
}

.jc-roadmap-banner h2 span {
  color: #a5c0ff;
}

.jc-roadmap-banner p {
  font-size: clamp(18px, 2.5vw, 28px);
  color: rgba(255,255,255,0.75);
  margin-top: 18px;
  font-weight: 600;
  position: relative;
  z-index: 1;
  letter-spacing: -0.5px;
}

/* ── 본문 ── */
.jc-roadmap-body {
  padding: 50px 24px 70px;
}

/* ── 연도 ── */
.jc-roadmap-year {
  display: flex;
  align-items: center;
  gap: 20px;
  margin: 50px 0 24px;
}

.jc-roadmap-year:first-child { margin-top: 0; }

.jc-roadmap-year-label {
  font-size: clamp(24px, 3.5vw, 44px);
  font-weight: 900;
  color: #3b5bdb;
  white-space: nowrap;
  letter-spacing: -1px;
  background: #dbe4ff;
  padding: 6px 22px;
  border-radius: 50px;
}

.jc-roadmap-year-line {
  flex: 1;
  height: 3px;
  background: linear-gradient(to right, #3b5bdb, transparent);
  border-radius: 3px;
}

/* ── 그리드 ── */
.jc-roadmap-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

@media (max-width: 900px) {
  .jc-roadmap-grid { grid-template-columns: repeat(3, 1fr); gap: 12px; }
}

@media (max-width: 600px) {
  .jc-roadmap-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .jc-roadmap-banner { padding: 80px 24px 70px; }
}

/* ── 카드 ── */
.jc-month-card {
  background: #ffffff;
  border-radius: 18px;
  padding: 16px 14px;
  border: 2px solid #dbe4ff;
  box-shadow: 0 4px 16px rgba(59,91,219,0.08);
  position: relative;
  overflow: hidden;
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.2s, border-color 0.2s;
}

.jc-month-card.visible { opacity: 1; transform: translateY(0); }
.jc-month-card.visible:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(59,91,219,0.16); border-color: #3b5bdb; }

.jc-month-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(to right, #3b5bdb, #748ffc);
  border-radius: 18px 18px 0 0;
}

/* ── 월 헤더 ── */
.jc-month-header {
  margin-bottom: 10px;
  padding-bottom: 10px;
  border-bottom: 2px solid #eef0ff;
}

.jc-month-name {
  font-size: clamp(22px, 3vw, 38px);
  font-weight: 900;
  color: #3b5bdb;
  letter-spacing: -1px;
  line-height: 1.1;
}

/* ── 강의 목록 ── */
.jc-month-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.jc-month-list li {
  font-size: clamp(13px, 1.6vw, 18px);
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: -0.3px;
}

/* 링크 있는 항목 */
.jc-month-list li a {
  display: block;
  color: #1a1a2e;
  text-decoration: none;
  padding: 5px 8px 5px 20px;
  border-radius: 8px;
  position: relative;
  transition: background 0.18s, color 0.18s, transform 0.15s;
  word-break: keep-all;
}

.jc-month-list li a::before {
  content: '▸';
  position: absolute;
  left: 4px; top: 6px;
  color: #3b5bdb;
  font-size: 12px;
  transition: color 0.18s;
}

.jc-month-list li a:hover {
  background: #3b5bdb;
  color: #ffffff;
  transform: translateX(3px);
}

.jc-month-list li a:hover::before { color: #ffffff; }

/* 링크 없는 항목 */
.jc-month-list li span.jc-item {
  display: block;
  color: #666;
  padding: 5px 8px 5px 20px;
  border-radius: 8px;
  position: relative;
  word-break: keep-all;
}

.jc-month-list li span.jc-item::before {
  content: '▸';
  position: absolute;
  left: 4px; top: 6px;
  color: #ccc;
  font-size: 12px;
}

/* 날짜 뱃지 */
.jc-date {
