  font-size: clamp(11px, 1.2vw, 14px) !important;
  color: #3b5bdb;
  font-weight: 600;
  background: #eef0ff;
  padding: 1px 6px;
  border-radius: 5px;
  margin-left: 3px;
  vertical-align: middle;
  transition: background 0.18s, color 0.18s;
  white-space: nowrap;
}

.jc-month-list li a:hover .jc-date {
  background: rgba(255,255,255,0.25);
  color: #fff;
}

/* ── 노트 ── */
