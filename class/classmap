function gn(m){return m.split("-")[1].replace(/^0/,"");}
function gy(m){return m.split("-")[0];}
function i27(m){return gy(m)==="2027";}
function bm(a,m){return a.filter(function(c){return c.m===m;});}

function countUp(el,target,dur){
  var s=0,step=target/(dur/16);
  var t=setInterval(function(){
    s+=step;if(s>=target){s=target;clearInterval(t);}
    el.textContent=Math.floor(s).toLocaleString();
  },16);
}

var dly=0.28;
function nd(){var d=dly;dly+=0.025;return d;}

function cardHTML(c,tp){
  var fin=c.fin,on=c.on;
  var cls="card fu ";
  if(fin) cls+="c-fin";
  else if(tp==="u") cls+=(on?"cu-on":"cu-off");
  else              cls+=(on?"cl-on":"cl-off");
  if(c.url) cls+=" lnk";
  var oc=c.url?" onclick=\"window.open('"+c.url+"','_blank')\"":"";
  var ar=c.url?"<span class='c-arr'>↗</span> ":"";
  var bdg=fin?"🎉 시리즈 완결":(on?"✅ 공개 완료":"📅 공개 예정");
  var d=nd();
  return "<div class='"+cls+"'"+oc+" style='animation-delay:"+d.toFixed(2)+"s;animation-play-state:paused;'>"
    +"<div class='c-date'>"+c.d+"</div>"
    +"<div class='c-body'>"
      +"<div class='c-title'>"+ar+c.t+"</div>"
      +"<div class='c-sub'>"+c.s+(fin?" 🎉":"")+"</div>"
      +"<div class='c-status'>"+bdg+"</div>"
    +"</div>"
    +"</div>";
}

function render(){
  var out=document.getElementById("jcrm10-content");if(!out)return;
  var html="",prevYr="";
  MONTHS.forEach(function(m){
    var uc=bm(U,m),lc=bm(L,m);
    if(!uc.length&&!lc.length)return;
    var yr=gy(m),y=i27(m);
    if(yr!==prevYr){
      prevYr=yr;
      html+="<div class='year-banner fl' style='animation-delay:"+nd().toFixed(2)+"s;animation-play-state:paused;'>"
        +"<div class='year-num "+(y?"y27":"y26")+"'>"+yr+"</div>"
        +"<div class='year-line "+(y?"y27":"y26")+"'></div></div>";
    }
    html+="<div class='month-section' id='jms10-"+m+"' data-ms='"+m+"'>";
    html+="<div class='month-head "+(y?"y27":"y26")+" fl' style='animation-delay:"+nd().toFixed(2)+"s;animation-play-state:paused;'>"
      +"<span class='month-num-big'>"+gn(m)+"</span>"
      +"<span class='month-ko'>월</span></div>";
    if(uc.length){
      html+="<div class='course-lbl u'><div class='course-lbl-dot'></div>전공 과정</div>";
      html+="<div class='card-grid' style='margin-bottom:16px;'>";
      uc.forEach(function(c){html+=cardHTML(c,"u");});
      html+="</div>";
    }
    if(lc.length){
      html+="<div class='course-lbl l'><div class='course-lbl-dot'></div>평생 과정</div>";
      html+="<div class='card-grid'>";
      lc.forEach(function(c){html+=cardHTML(c,"l");});
      html+="</div>";
    }
    html+="</div><div class='divider'></div>";
  });
  out.innerHTML=html;
  if("IntersectionObserver" in window){
    var obs=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){e.target.style.animationPlayState="running";obs.unobserve(e.target);}
      });
    },{threshold:0.02,rootMargin:"0px 0px -20px 0px"});
    document.querySelectorAll("#jcrm10 .fu,#jcrm10 .fl").forEach(function(el){obs.observe(el);});
  }
}

function buildNav(){
  var nav=document.getElementById("jcrm10-nav");if(!nav)return;
  var active=MONTHS.filter(function(m){return bm(U,m).length||bm(L,m).length;});
  var html="<div class='nav-inner' id='jcrm10-ni'>";
  var prevYr="";
  active.forEach(function(m){
    var yr=gy(m),y=i27(m);
    if(yr!==prevYr){
      if(prevYr) html+="<div class='nav-divider'></div>";
      html+="<div class='nav-year-lbl "+(y?"y27":"y26")+"'>"+yr+"</div>";
      prevYr=yr;
    }
    html+="<button class='nav-btn' data-m='"+m+"' onclick='jcrm10Go(\""+m+"\")'>"
      +"<span class='nav-num'>"+gn(m)+"</span>"
      +"<span class='nav-ko'>월</span></button>";
  });
  html+="</div>";
  var hint=nav.querySelector(".nav-hint");
  nav.innerHTML="";
  if(hint)nav.appendChild(hint);
  var tmp=document.createElement("div");
  tmp.innerHTML=html;
  nav.appendChild(tmp.firstChild);
  if(active.length)setAct(active[0]);
}

function setAct(m){
  document.querySelectorAll("#jcrm10-nav .nav-btn").forEach(function(b){
    b.classList.remove("on26","on27");
    if(b.getAttribute("data-m")===m){
      b.classList.add(i27(m)?"on27":"on26");
      var ni=document.getElementById("jcrm10-ni");
      if(ni)ni.scrollTo({left:b.offsetLeft-ni.offsetWidth/2+b.offsetWidth/2,behavior:"smooth"});
    }
  });
}

window.jcrm10Go=function(m){
  var el=document.getElementById("jms10-"+m);if(!el)return;
  var nav=document.getElementById("jcrm10-nav");
  var off=(nav?nav.offsetHeight:70)+10;
  window.scrollTo({top:el.getBoundingClientRect().top+window.pageYOffset-off,behavior:"smooth"});
  setAct(m);
};

(function(){
  var tick=false;
  window.addEventListener("scroll",function(){
    if(tick)return;tick=true;
    requestAnimationFrame(function(){
      var nav=document.getElementById("jcrm10-nav");
      var navH=nav?nav.offsetHeight:70;
      var cur=null;
      document.querySelectorAll("[data-ms]").forEach(function(s){
        if(s.getBoundingClientRect().top<=navH+80)cur=s.getAttribute("data-ms");
      });
      if(cur)setAct(cur);
      tick=false;
    });
  });
})();

function initCounter(){
  var eu=document.getElementById("jcrm10-cu");
  var el=document.getElementById("jcrm10-cl");
  var stat=document.querySelector("#jcrm10 .hd-stats");
  function start(){if(eu)countUp(eu,1316,1800);if(el)countUp(el,2564,1800);}
  if("IntersectionObserver" in window&&stat){
    var o=new IntersectionObserver(function(e){if(e[0].isIntersecting){start();o.disconnect();}},{threshold:0.3});
    o.observe(stat);
  }else{start();}
}

function init(){render();buildNav();initCounter();}
if(document.readyState==="loading"){document.addEventListener("DOMContentLoaded",init);}
else{init();}
