<!-- 정철대학 로드맵 v10 | 칠판 레트로 | 워드프레스 완전호환 -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800;900&family=Special+Elite&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet">

<style id="jcrm10-css">
/* ── 엘리멘토 여백 제거 ── */
.elementor-widget-html .elementor-widget-container,
.elementor-widget-html .elementor-column-wrap,
.elementor-widget-html .elementor-column,
.elementor-widget-html .elementor-row,
.elementor-widget-html .e-con-inner {
  padding-left:0!important; padding-right:0!important; max-width:100%!important;
}
#jcrm10-outer {
  width:100vw; position:relative; left:50%; margin-left:-50vw;
  overflow-x:hidden; box-sizing:border-box;
}

/* ════════════════════════════════
   칠판 팔레트
   배경:    #243c32 (칠판 녹색)
   테두리:  #3c2812 (나무 액자 갈색)
   흰분필:  #F5F0E8 (전공 완료)
   황토분필: #F0C080 (평생 완료)
   노란분필: #FFE500 (완결 — 형광)
   예정:    희미한 점선 카드 + 전체 깜빡임
════════════════════════════════ */

#jcrm10 {
  font-family:'Pretendard','Apple SD Gothic Neo','Noto Sans KR',sans-serif;
  background:#243c32;
  color:#F5F0E8;
  box-sizing:border-box; width:100%;
  -webkit-font-smoothing:antialiased;
}
#jcrm10 * { box-sizing:inherit; }

/* ── 키프레임 ── */
@keyframes jc10-up    { from{opacity:0;transform:translateY(14px);}  to{opacity:1;transform:translateY(0);} }
@keyframes jc10-left  { from{opacity:0;transform:translateX(-12px);} to{opacity:1;transform:translateX(0);} }
@keyframes jc10-in    { from{opacity:0;} to{opacity:1;} }
@keyframes jc10-blink { 0%,100%{opacity:1;} 50%{opacity:0.22;} }
@keyframes jc10-uline { from{width:0;} to{width:100%;} }

/* ════ 헤더 ════ */
#jcrm10 .hd {
  background:linear-gradient(175deg,#182c22 0%,#243c32 55%,#2a4438 100%);
  padding:130px 60px 120px;
  display:flex; flex-direction:column; align-items:center;
  text-align:center; gap:26px; position:relative; overflow:hidden;
  border-bottom:4px solid #3a6050;
  animation:jc10-in .8s ease both;
}
/* 나무 액자 */
#jcrm10 .hd::before {
  content:''; position:absolute; inset:0;
  border:20px solid #3c2812;
  box-shadow:inset 0 0 0 3px #5c3d1e, inset 0 0 0 5px #3c2812;
  pointer-events:none; z-index:2;
}
#jcrm10 .hd-inner { position:relative; z-index:3; width:100%; display:flex; flex-direction:column; align-items:center; gap:22px; }
#jcrm10 .hd-dash {
  width:70%; height:2px;
  background:repeating-linear-gradient(90deg,rgba(245,240,232,.4) 0,rgba(245,240,232,.4) 10px,transparent 10px,transparent 18px);
}
#jcrm10 .hd-eyebrow {
  font-family:'Special Elite',serif;
  font-size:14px; letter-spacing:7px; color:rgba(255,229,0,.75); text-transform:uppercase;
  animation:jc10-up .6s ease .1s both;
}
#jcrm10 .hd-title {
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  font-size:72px; font-weight:900; line-height:1.18; margin:0;
  color:#F5F0E8; letter-spacing:-2px;
  text-shadow:3px 3px 0 rgba(0,0,0,.28);
  animation:jc10-up .7s ease .2s both;
}
#jcrm10 .hd-title-wrap { position:relative; display:inline-block; }
#jcrm10 .hd-title-wrap::after {
  content:''; position:absolute; bottom:-6px; left:0;
  height:4px; width:0; border-radius:2px;
  background:repeating-linear-gradient(90deg,#FFE500 0,#FFE500 10px,transparent 10px,transparent 16px);
  animation:jc10-uline 1.2s ease .95s forwards;
}
#jcrm10 .hd-sub {
  font-family:'Pretendard',sans-serif;
  font-size:22px; color:rgba(245,240,232,.65); font-weight:600; margin:0;
  letter-spacing:1px;
  animation:jc10-up .6s ease .3s both;
}
#jcrm10 .hd-stats {
  display:flex; gap:20px; justify-content:center; flex-wrap:wrap;
  animation:jc10-up .6s ease .4s both;
}
#jcrm10 .hd-stat {
  padding:22px 44px; border-radius:6px; text-align:center; position:relative;
}
#jcrm10 .hd-stat::before { content:''; position:absolute; inset:0; border:2px solid; border-radius:6px; }
#jcrm10 .st-u { background:rgba(245,240,232,.07); }
#jcrm10 .st-u::before { border-color:rgba(245,240,232,.4); }
#jcrm10 .st-l { background:rgba(240,192,128,.07); }
#jcrm10 .st-l::before { border-color:rgba(240,192,128,.4); }
#jcrm10 .hd-n {
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  font-size:54px; font-weight:900; line-height:1; letter-spacing:-2px;
}
#jcrm10 .st-u .hd-n { color:#F5F0E8; }
#jcrm10 .st-l .hd-n { color:#F0C080; }
#jcrm10 .hd-t { font-family:'Pretendard',sans-serif; font-size:16px; color:rgba(245,240,232,.55); font-weight:700; margin-top:6px; }

/* ════ 범례 ════ */
#jcrm10 .legend {
  display:flex; gap:12px; justify-content:center; flex-wrap:wrap;
  padding:18px 32px;
  background:linear-gradient(180deg,#2a4438,#243c32);
  border-bottom:2px solid #3a6050;
  animation:jc10-up .5s ease .5s both;
}
#jcrm10 .leg {
  display:flex; align-items:center; gap:8px;
  padding:9px 18px; border-radius:4px;
  font-family:'Pretendard',sans-serif;
  font-size:16px; font-weight:800; border:1px solid;
}
#jcrm10 .leg-dot { width:10px; height:10px; border-radius:2px; flex-shrink:0; }

/* ════ 월 탭 네비 ════ */
#jcrm10 .month-nav {
  position:sticky; top:0; z-index:999;
  background:rgba(24,44,34,.97);
  backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px);
  border-bottom:3px solid #3a6050;
}
#jcrm10 .nav-hint {
  text-align:center;
  font-family:'Pretendard',sans-serif;
  font-size:14px; font-weight:700; letter-spacing:3px;
  color:rgba(255,229,0,.6);
  padding:7px 0 4px;
  border-bottom:1px dashed rgba(255,229,0,.18);
}
#jcrm10 .nav-inner {
  display:flex; align-items:stretch; overflow-x:auto;
  scrollbar-width:none; padding:0 16px;
}
#jcrm10 .nav-inner::-webkit-scrollbar { display:none; }
#jcrm10 .nav-year-lbl {
  display:flex; align-items:center;
  font-family:'Special Elite',serif;
  font-size:12px; letter-spacing:3px;
  padding:0 14px 0 4px; flex-shrink:0;
  border-right:1px dashed rgba(245,240,232,.18); margin-right:4px;
}
#jcrm10 .nav-year-lbl.y26 { color:rgba(255,229,0,.8); }
#jcrm10 .nav-year-lbl.y27 { color:rgba(240,192,128,.85); }
#jcrm10 .nav-divider { width:1px; background:rgba(255,255,255,.1); margin:8px 4px; flex-shrink:0; }
#jcrm10 .nav-btn {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:10px 16px; background:none; border:none; cursor:pointer;
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  color:rgba(245,240,232,.32); white-space:nowrap; flex-shrink:0;
  position:relative; transition:color .18s; gap:2px;
}
#jcrm10 .nav-btn::after {
  content:''; position:absolute; bottom:0; left:50%; right:50%;
  height:3px; background:#FFE500; transition:left .2s,right .2s; border-radius:3px 3px 0 0;
}
#jcrm10 .nav-btn:hover { color:rgba(245,240,232,.8); }
#jcrm10 .nav-btn:hover::after { left:8%; right:8%; }
#jcrm10 .nav-btn.on26 { color:#F5F0E8; }
#jcrm10 .nav-btn.on26::after { left:8%; right:8%; background:#FFE500; }
#jcrm10 .nav-btn.on27 { color:#F0C080; }
#jcrm10 .nav-btn.on27::after { left:8%; right:8%; background:#F0C080; }
#jcrm10 .nav-num { font-size:28px; font-weight:900; line-height:1; }
#jcrm10 .nav-ko  { font-size:12px; font-weight:700; opacity:.6; }

/* ════ 연도 배너 ════ */
#jcrm10 .year-banner {
  padding:36px 44px 18px; display:flex; align-items:center; gap:20px;
}
#jcrm10 .year-num {
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  font-size:86px; font-weight:900; line-height:1; letter-spacing:-4px;
}
#jcrm10 .year-num.y26 { color:#FFE500; text-shadow:2px 2px 0 rgba(0,0,0,.3); }
#jcrm10 .year-num.y27 { color:#F0C080; text-shadow:2px 2px 0 rgba(0,0,0,.3); }
#jcrm10 .year-line { flex:1; height:2px; }
#jcrm10 .year-line.y26 { background:repeating-linear-gradient(90deg,#FFE500 0,#FFE500 8px,transparent 8px,transparent 14px); opacity:.4; }
#jcrm10 .year-line.y27 { background:repeating-linear-gradient(90deg,#F0C080 0,#F0C080 8px,transparent 8px,transparent 14px); opacity:.4; }

/* ════ 월 섹션 ════ */
#jcrm10 .month-section { padding:0 44px 48px; }
#jcrm10 .month-head {
  display:flex; align-items:baseline; gap:10px;
  margin-bottom:28px; padding-left:16px; position:relative;
}
#jcrm10 .month-head::before {
  content:''; position:absolute; left:0; top:6px; bottom:6px;
  width:5px; border-radius:3px;
}
#jcrm10 .month-head.y26::before { background:#FFE500; box-shadow:0 0 12px rgba(255,229,0,.55); }
#jcrm10 .month-head.y27::before { background:#F0C080; box-shadow:0 0 12px rgba(240,192,128,.55); }
#jcrm10 .month-num-big {
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  font-size:72px; font-weight:900; color:#F5F0E8; line-height:1; letter-spacing:-3px;
  text-shadow:2px 2px 0 rgba(0,0,0,.3);
}
#jcrm10 .month-ko {
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  font-size:30px; font-weight:700; color:rgba(245,240,232,.5);
}

/* ════ 카드 그리드 ════ */
#jcrm10 .card-grid { display:grid; gap:16px; grid-template-columns:repeat(2,1fr); }
@media(min-width:900px)  { #jcrm10 .card-grid { grid-template-columns:repeat(3,1fr); } }
@media(min-width:1200px) { #jcrm10 .card-grid { grid-template-columns:repeat(4,1fr); } }

/* ════ 과정 라벨 ════ */
#jcrm10 .course-lbl {
  display:inline-flex; align-items:center; gap:8px;
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  font-size:20px; font-weight:900; letter-spacing:2px;
  margin-bottom:14px; padding:4px 0;
}
#jcrm10 .course-lbl.u { color:#F5F0E8; }
#jcrm10 .course-lbl.l { color:#F0C080; }
#jcrm10 .course-lbl-dot { width:8px; height:8px; border-radius:2px; }
#jcrm10 .course-lbl.u .course-lbl-dot { background:#FFE500; }
#jcrm10 .course-lbl.l .course-lbl-dot { background:#F0C080; }

/* ════ 카드 기본 ════ */
#jcrm10 .card {
  border-radius:6px;
  display:flex; flex-direction:column;
  min-height:210px; position:relative; overflow:hidden;
  transition:transform .22s ease, box-shadow .22s ease, filter .22s ease;
  cursor:default; border:2px solid;
}
#jcrm10 .card.lnk { cursor:pointer; }

/* ── hover 모션 (공개 완료 카드) ── */
#jcrm10 .cu-on:hover,
#jcrm10 .cl-on:hover,
#jcrm10 .c-fin:hover {
  transform:translateY(-6px) scale(1.02);
  filter:brightness(1.12);
}
#jcrm10 .cu-on:hover { box-shadow:6px 6px 0 rgba(0,0,0,.4), 0 0 36px rgba(245,240,232,.18); }
#jcrm10 .cl-on:hover { box-shadow:6px 6px 0 rgba(0,0,0,.4), 0 0 36px rgba(240,192,128,.18); }
#jcrm10 .c-fin:hover { box-shadow:6px 6px 0 rgba(0,0,0,.4), 0 0 40px rgba(255,229,0,.35); }

/* ── 공개예정 카드: 카드 전체 깜빡 ── */
#jcrm10 .cu-off { animation:jc10-blink 2.6s ease-in-out infinite; }
#jcrm10 .cl-off { animation:jc10-blink 2.6s ease-in-out infinite; }

/* 칠판 텍스처 줄 */
#jcrm10 .card::after {
  content:'';
  position:absolute; inset:0; pointer-events:none;
  background:repeating-linear-gradient(
    90deg, transparent 0, transparent 44px,
    rgba(255,255,255,.013) 44px, rgba(255,255,255,.013) 45px
  );
}

/* 전공 완료 — 흰 분필 */
#jcrm10 .cu-on {
  background:linear-gradient(145deg,#1c3028 0%,#263c30 50%,#2c4438 100%);
  border-color:rgba(245,240,232,.65);
  box-shadow:4px 4px 0 rgba(0,0,0,.35);
}
/* 전공 예정 */
#jcrm10 .cu-off {
  background:rgba(245,240,232,.035);
  border-color:rgba(245,240,232,.2);
  border-style:dashed;
}
/* 평생 완료 — 황토 분필 */
#jcrm10 .cl-on {
  background:linear-gradient(145deg,#1a2c24 0%,#243428 50%,#2a3c30 100%);
  border-color:rgba(240,192,128,.6);
  box-shadow:4px 4px 0 rgba(0,0,0,.35);
}
/* 평생 예정 */
#jcrm10 .cl-off {
  background:rgba(240,192,128,.035);
  border-color:rgba(240,192,128,.2);
  border-style:dashed;
}
/* 시리즈 완결 — 형광 노란 분필 */
#jcrm10 .c-fin {
  background:linear-gradient(145deg,#2a2800 0%,#3a3400 50%,#444000 100%);
  border-color:#FFE500; border-width:3px;
  box-shadow:4px 4px 0 rgba(0,0,0,.4), 0 0 28px rgba(255,229,0,.22);
}

/* ════ 날짜 배지 — 전체 가로 ════ */
#jcrm10 .c-date {
  display:block; width:100%;
  padding:12px 20px;
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  font-size:20px; font-weight:800; letter-spacing:1px;
  position:relative; z-index:1;
  border-bottom:2px solid;
}
#jcrm10 .cu-on  .c-date { background:rgba(245,240,232,.12); color:#F5F0E8; border-color:rgba(245,240,232,.25); }
#jcrm10 .cu-off .c-date { background:rgba(245,240,232,.06); color:rgba(245,240,232,.45); border-color:rgba(245,240,232,.12); }
#jcrm10 .cl-on  .c-date { background:rgba(240,192,128,.12); color:#F0C080; border-color:rgba(240,192,128,.25); }
#jcrm10 .cl-off .c-date { background:rgba(240,192,128,.06); color:rgba(240,192,128,.45); border-color:rgba(240,192,128,.12); }
#jcrm10 .c-fin  .c-date { background:rgba(255,229,0,.15); color:#FFE500; border-color:rgba(255,229,0,.4); }

/* 카드 본문 패딩 */
#jcrm10 .c-body { padding:18px 20px 20px; display:flex; flex-direction:column; gap:12px; flex:1; }

/* ════ 제목 — 하이라이터 효과 ════ */
#jcrm10 .c-title {
  font-family:'Pretendard','Apple SD Gothic Neo',sans-serif;
  font-size:28px; font-weight:900; line-height:1.3;
  position:relative; z-index:1; display:inline;
}
/* 공개 완료: 하이라이터 배경 */
#jcrm10 .cu-on .c-title {
  background:linear-gradient(transparent 50%, rgba(245,240,232,.22) 50%);
  color:#FFFFFF;
  text-shadow:1px 1px 0 rgba(0,0,0,.3);
  padding-bottom:2px;
}
#jcrm10 .cu-off .c-title { color:rgba(245,240,232,.4); }
#jcrm10 .cl-on .c-title {
  background:linear-gradient(transparent 50%, rgba(240,192,128,.2) 50%);
  color:#FFE8C0;
  text-shadow:1px 1px 0 rgba(0,0,0,.3);
  padding-bottom:2px;
}
#jcrm10 .cl-off .c-title { color:rgba(240,192,128,.4); }
#jcrm10 .c-fin .c-title {
  background:linear-gradient(transparent 45%, rgba(255,229,0,.25) 45%);
  color:#FFE500;
  text-shadow:1px 1px 0 rgba(0,0,0,.4), 0 0 18px rgba(255,229,0,.35);
  padding-bottom:2px;
}

/* ════ 서브 텍스트 ════ */
#jcrm10 .c-sub {
  font-size:18px; font-weight:600; line-height:1.65;
  flex:1; position:relative; z-index:1;
}
#jcrm10 .cu-on  .c-sub { color:rgba(245,240,232,.78); }
#jcrm10 .cu-off .c-sub { color:rgba(245,240,232,.28); }
#jcrm10 .cl-on  .c-sub { color:rgba(240,192,128,.78); }
#jcrm10 .cl-off .c-sub { color:rgba(240,192,128,.28); }
#jcrm10 .c-fin  .c-sub { color:rgba(255,229,0,.68); }

/* ════ 상태 배지 ════ */
#jcrm10 .c-status {
  display:inline-flex; align-items:center; gap:6px;
  padding:8px 16px; border-radius:4px;
  font-family:'Pretendard',sans-serif;
  font-size:16px; font-weight:900;
  align-self:flex-start; position:relative; z-index:1;
}
#jcrm10 .cu-on  .c-status { background:#F5F0E8; color:#1e3028; }
#jcrm10 .cu-off .c-status { background:transparent; color:rgba(245,240,232,.35); border:1px dashed rgba(245,240,232,.2); }
#jcrm10 .cl-on  .c-status { background:#F0C080; color:#1e2820; }
#jcrm10 .cl-off .c-status { background:transparent; color:rgba(240,192,128,.35); border:1px dashed rgba(240,192,128,.2); }
#jcrm10 .c-fin  .c-status { background:#FFE500; color:#1a1a00; font-size:17px; font-weight:900; }

#jcrm10 .c-arr { font-size:14px; opacity:.55; }

/* 구분선 */
#jcrm10 .divider {
  height:2px; margin:0 44px 40px;
  background:repeating-linear-gradient(90deg,rgba(245,240,232,.15) 0,rgba(245,240,232,.15) 8px,transparent 8px,transparent 16px);
}

/* 카드 등장 */
#jcrm10 .fu { opacity:0; animation:jc10-up  .25s ease forwards; }
#jcrm10 .fl { opacity:0; animation:jc10-left .22s ease forwards; }

/* 푸터 */
#jcrm10 .foot {
  text-align:center; padding:28px 20px;
  font-family:'Special Elite',serif;
  font-size:16px; color:rgba(245,240,232,.3);
  background:#182c22; border-top:2px solid #3a6050;
}

/* ════════════════════════════════
   모바일 최적화
════════════════════════════════ */
@media(max-width:767px) {
  #jcrm10 .hd         { padding:100px 22px 90px; }
  #jcrm10 .hd::before { border-width:10px; }
  #jcrm10 .hd-title   { font-size:44px; letter-spacing:-1px; }
  #jcrm10 .hd-sub     { font-size:18px; }
  #jcrm10 .hd-n       { font-size:48px; }
  #jcrm10 .hd-stat    { padding:18px 30px; }
  #jcrm10 .hd-stats   { gap:14px; }
  #jcrm10 .hd-eyebrow { font-size:12px; letter-spacing:5px; }

  #jcrm10 .legend     { padding:14px 12px; gap:8px; }
  #jcrm10 .leg        { font-size:14px; padding:8px 14px; }

  #jcrm10 .nav-hint   { font-size:13px; letter-spacing:2px; }
  #jcrm10 .nav-num    { font-size:26px; }

  #jcrm10 .year-banner    { padding:24px 18px 14px; }
  #jcrm10 .year-num       { font-size:64px; }
  #jcrm10 .month-section  { padding:0 14px 36px; }
  #jcrm10 .month-num-big  { font-size:60px; }
  #jcrm10 .month-ko       { font-size:24px; }
  #jcrm10 .course-lbl     { font-size:18px; }
  #jcrm10 .divider        { margin:0 14px 28px; }

  /* 모바일 카드: 1열 + 더 큰 텍스트 */
  #jcrm10 .card-grid  { grid-template-columns:1fr; gap:14px; }
  #jcrm10 .c-date     { font-size:19px; padding:12px 18px; }
  #jcrm10 .c-title    { font-size:26px; }
  #jcrm10 .c-sub      { font-size:17px; }
  #jcrm10 .c-status   { font-size:15px; padding:8px 14px; }
  #jcrm10 .c-body     { padding:16px 18px 18px; gap:10px; }
}
</style>

<div id="jcrm10-outer">
<div id="jcrm10">

  <!-- 헤더 -->
  <div class="hd">
    <div class="hd-inner">
      <div class="hd-eyebrow">JungChul University</div>
