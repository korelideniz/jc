function moCard(c,tp,delay){
  var base=tp==="u"?(c.on?"cu-on":"cu-off"):(c.on?"cl-on":"cl-off");
  var lnk=c.link?' lnk onclick="window.open(\''+c.link+'\',\'_blank\')"':'';
  var arr=c.link?' <span style="opacity:.55">↗</span>':'';
  var status=c.on?"✅ 공개 완료":"📅 공개 예정";
  return '<div class="mo-card mo-card-anim '+base+'"'+lnk+' style="animation-delay:'+(delay||0)+'s;">'
    +'<div class="c-date-pill">'+c.d+'</div>'
    +'<div class="c-title">'+c.t+arr+'</div>'
    +'<div class="c-sub">'+c.s+'</div>'
    +'<div class="c-status">'+status+'</div>'
    +'</div>';
}

