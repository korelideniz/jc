var MONTHS=["2026-04","2026-05","2026-06","2026-07","2026-08","2026-09",
  "2026-10","2026-11","2026-12","2027-01","2027-02","2027-03","2027-04",
  "2027-05","2027-06","2027-07","2027-08","2027-09","2027-10","2027-11","2027-12"];

function gn(m){return m.split("-")[1].replace(/^0/,"");}
function gy(m){return m.split("-")[0];}
function y27(m){return gy(m)==="2027";}
function bm(arr,m){return arr.filter(function(c){return c.m===m;});}

function card(c,tp,delay){
  var base=tp==="u"?(c.on?"cu-on":"cu-off"):(c.on?"cl-on":"cl-off");
  var lnk=c.link?' lnk onclick="window.open(\''+c.link+'\',\'_blank\')"':'';
  var arr=c.link?' <span style="font-size:13px;opacity:.55">↗</span>':'';
  var status=c.on?"✅ 공개 완료":"📅 공개 예정";
  var anim=' card-anim" style="animation-delay:'+(delay||0)+'s;';
  return '<div class="card '+base+anim+'"'+lnk+'>'
    +'<div class="c-date-pill">'+c.d+'</div>'
    +'<div class="c-title">'+c.t+arr+'</div>'
    +'<div class="c-sub">'+c.s+'</div>'
    +'<div class="c-status">'+status+'</div>'
    +'</div>';
}

function renderDesktop(){
  var w=document.getElementById("tw"); if(!w)return;
  var h='<table class="tbl"><thead><tr>';
  h+='<th class="lth"></th>';
  var cardDelay=0.4;
  MONTHS.forEach(function(m){
    var c27=y27(m)?" y27":"";
    var is2026Start=(!y27(m)&&gn(m)==="4"); /* 2026-04 = 첫 월 */
    h+='<th class="mth'+c27+'"><div class="mc">';
    if(is2026Start) h+='<div class="y26b">2026년</div><br>';
    if(y27(m)&&gn(m)==="1") h+='<div class="y27b">2027년</div><br>';
    h+='<span class="mn">'+gn(m)+'</span><span class="mk">월</span>';
    h+='</div></th>';
  });
  h+='</tr></thead><tbody>';

  /* 타임라인 */
  h+='<tr class="tlrow"><td class="tl-lbl"></td>';
  MONTHS.forEach(function(m){h+='<td><div class="tlbar"></div></td>';});
  h+='</tr>';
  h+='<tr class="spacer-row"><td></td>'+MONTHS.map(function(){return '<td></td>';}).join('')+'</tr>';

  /* 전공과정 */
  h+='<tr>';
  h+='<td class="ltd"><div class="lbl-box lbl-box-u"><div class="lbl-main lbl-u">📘<br>전공<br>과정</div></div></td>';
  MONTHS.forEach(function(m){
    var cs=bm(U,m);
    h+='<td class="ctd">';
    if(cs.length){cs.forEach(function(c,i){h+=card(c,"u",cardDelay+i*0.08);cardDelay+=0.04;});}
    else h+='<div class="empty"></div>';
    h+='</td>';
  });
  h+='</tr>';
  h+='<tr class="spacer-row"><td></td>'+MONTHS.map(function(){return '<td></td>';}).join('')+'</tr>';

  /* 평생과정 */
