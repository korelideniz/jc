/* ================================================
   ★ FIXED BAR 위치 조절 패널 ★
   여기 숫자만 바꾸면 됩니다
   양수 = 오른쪽/아래로, 음수 = 왼쪽/위로
   ================================================ */
:root {

    /* ── PC: 바 전체 ── */
    --fb-pc-bottom: 20px;
    /* 바 자체 화면 하단 여백 */
    --fb-pc-pad-top: 20px;
    /* 바 내부 위 여백 */
    --fb-pc-pad-bottom: 20px;
    /* 바 내부 아래 여백 */
    --fb-pc-pad-left: 40px;
    /* 바 내부 왼쪽 여백 */
    --fb-pc-pad-right: 40px;
    /* 바 내부 오른쪽 여백 */

    /* ── PC: "지금 바로 구독하기" 제목 ── */
    --fb-pc-title-left: 0px;
    /* 제목 좌우 (양수=오른쪽) */
    --fb-pc-title-top: -5px;
    /* 제목 상하 (양수=아래) */

    /* ── PC: "9,900원 4,900원" 가격 ── */
    --fb-pc-price-left: 0px;
    /* 가격 좌우 (제목과의 간격) */
    --fb-pc-price-top: -28px;
    /* 가격 상하 (양수=아래) */

    /* ── PC: "바로 구독하기" 버튼 ── */
    --fb-pc-btn-right: 150px;
    /* 버튼 좌우 (양수=오른쪽, 음수=왼쪽) */
    --fb-pc-btn-top: 15px;
    /* 버튼 상하 (양수=아래, 음수=위) */

    /* ── 모바일: 바 전체 ── */
    --fb-mo-bottom: 0px;
    /* 바 자체 화면 하단 여백 */
    --fb-mo-pad-top: 20px;
    /* 바 내부 위 여백 */
    --fb-mo-pad-bottom: 40px;
    /* 바 내부 아래 여백 (홈바 공간) */
    --fb-mo-pad-left: 20px;
    /* 바 내부 왼쪽 여백 */
    --fb-mo-pad-right: 20px;
    /* 바 내부 오른쪽 여백 */

    /* ── 모바일: "지금 바로 구독하기" 제목 ── */
    --fb-mo-title-left: 0px;
    /* 제목 좌우 (양수=오른쪽) */
    --fb-mo-title-top: 20px;
    /* 제목 상하 (양수=아래) */

    /* ── 모바일: "9,900원 4,900원" 가격 ── */
    --fb-mo-price-left: 14px;
    /* 가격 좌우 (양수=오른쪽) */
    --fb-mo-price-top: 0px;
    /* 가격 상하 (양수=아래) */

    /* ── 모바일: "바로 구독하기" 버튼 ── */
    --fb-mo-btn-right: -150px;
    /* 버튼 좌우 (양수=오른쪽, 음수=왼쪽) */
    --fb-mo-btn-top: 10px;
    /* 버튼 상하 (양수=아래, 음수=위) */

}

