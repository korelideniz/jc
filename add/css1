.quantity input.qty::-webkit-outer-spin-button {
    -webkit-appearance: none !important;
}

btn {
    width: 36px !important;
    height: 36px !important;
    border-radius: 50% !important;
    border: 2px solid #95292A !important;
    background: #fff !important;
    color: #95292A !important;
    font-size: 20px !important;

    font @media (max-width: 768px) {
        .elementor-element-8581253 {
            order: -1 !important;
        }

        .elementor-element-8581253 .elementor-widget-wl-single-product-title {
            display: none !important;
        }
    }

    @media (max-width: 768px) {
        .elementor-element-8581253 {
            width: 100% !important;
            box-sizing: border-box !important;
            padding: 0 16px !important;
            margin: 16px 0 !important;
        }

        .elementor-element-fc57e5f {
            border-radius: 12px !important;
            border: 1px solid #e0e0e0 !important;
            padding: 20px !important;
        }

        [data-id="9193afd"]>.elementor-widget-wrap {
            padding: 20px !important;
            gap: 12px !important;
        }

        .elementor-widget-wl-product-add-to-cart form.cart {
            flex-wrap: wrap !important;
        }

        .elementor-widget-wl-product-add-to-cart form.cart .single_add_to_cart_button,
        .elementor-widget-wl-product-add-to-cart form.cart .cosmosfarm-quick-buy {
            flex: 1 1 40% !important;
            padding: 14px 10px !important;
            font-size: 15px !important;
            white-space: nowrap !important;
        }
    }
}
